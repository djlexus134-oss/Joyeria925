# Copiar en el VPS a /etc/joyeria925/env (chmod 600, propietario root o deploy)
# Usado por deploy/scripts/*.sh
# Rutas distintas a /etc/joyeria y /var/www/joyeria si ya hay otro proyecto en el VPS.

JOYERIA_DOMAIN=tu-dominio.com
# IPv4 del VPS (para verify-dns.sh; la misma que pones en Hostinger registro A)
JOYERIA_VPS_IP=
JOYERIA_WEB_ROOT=/var/www/joyeria925
JOYERIA_REPO=https://github.com/djlexus134-oss/Joyeria925.git
JOYERIA_BRANCH=main
JOYERIA_DEPLOY_USER=joyeria925-deploy

# SSL (setup-ssl.sh / certbot)
JOYERIA_SSL_EMAIL=
# JOYERIA_CERTBOT_STAGING=1

# Opcional: probar API en validate-domain.sh
# JOYERIA_CAJA_TOKEN=

# Socket PHP-FPM si autodetección falla: /run/php/php8.2-fpm.sock
# JOYERIA_PHP_FPM_SOCK=

DB_NAME=joyeria925
DB_USER=joyeria925_app
DB_PASSWORD=cambiar_password_seguro

# Solo para import inicial (opcional)
# JOYERIA_DB_DUMP=/root/backup_joyeria.sql
