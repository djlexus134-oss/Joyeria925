# Copia a .env (nunca subas .env al repositorio).
# Rellena solo en tu máquina o en el VPS.

DB_DRIVER=mysql
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_PORT=3306
DB_NAME=

# URL pública del sitio (sin /admin). Obligatoria en subcarpeta o Docker local.
# Ej. local: http://localhost:8080/Joyeria925
# Ej. prod:  https://plateria-el-angel.shop
JOYERIA_APP_URL=

# Zona horaria del negocio (Mexico). Evita fechas "un dia antes" si el servidor esta en UTC.
JOYERIA_TIMEZONE=America/Mexico_City

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=ssl
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=
SMTP_DEBUG=0

# Mercado Pago Checkout Pro (https://www.mercadopago.com.mx/developers)
# Usa credenciales TEST-... del panel de developers para pruebas en sandbox.
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
MP_NOTIFICATION_URL=
MP_RETURN_BASE=
# Modo: sandbox | produccion (afecta solo logs; la diferencia real depende del access token).
MP_MODO=sandbox